# Public hostname or IP that kids' WireGuard clients dial in to.
# Must be reachable from the public internet (DDNS or static IP + port-forward).
WG_HOST=vpn.example.com
WG_PORT=51820

# Subnet handed out to WG peers. Each device gets one /32 inside this range.
WG_SUBNET=10.13.13.0/24

# Admin UI passwords. `./gdlf init` auto-generates strong values for both
# if left as "change-me" (and writes the new values back here).
ADGUARD_ADMIN_PASSWORD=change-me
RULES_SVC_ADMIN_PASSWORD=change-me

# Dashboard bind
DASHBOARD_PORT=8080

# AdGuard admin UI bind (host port → AdGuard's :80 inside the wg netns).
ADGUARD_UI_PORT=8082

# Optional: webhook for flagged events (leave blank to disable)
ALERT_WEBHOOK_URL=

# Optional: SMTP for email digests (leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

# Timezone used by the scheduler
TZ=Europe/London

# Activity-log retention (hourly prune; daily VACUUM).
# Trim events older than N days, AND cap at N rows — whichever bites first.
RETENTION_DAYS=7
MAX_EVENTS=200000

# Per-domain counter rollup feeding the overview dashboard. Buckets are
# upserted in batch every STATS_FLUSH_SECS from an in-memory accumulator.
STATS_RETENTION_DAYS=7
STATS_BUCKET_SECS=300
STATS_FLUSH_SECS=30

# Apple MDM (only used when the `mdm` compose profile is enabled).
# MDM_HOSTNAME must be publicly resolvable. Caddy binds CADDY_HTTPS_PORT
# (not 80/443) and expects an upstream reverse proxy to SNI-passthrough
# mdm.<domain>:443 to <this-host>:CADDY_HTTPS_PORT. Let's Encrypt
# TLS-ALPN-01 challenges arrive via the same passthrough.
MDM_HOSTNAME=
ACME_EMAIL=
CADDY_HTTPS_PORT=8081
# Shared secret Caddy adds when forwarding /mdm/checkin and /mdm/server to
# rules-svc. `./gdlf init` auto-generates this if left as "change-me".
MDM_PROXY_SECRET=change-me
# Public URL devices use to reach the MDM endpoints. Must match the
# hostname+port reachable from the public internet (i.e. the router
# port-forward target). Typically `https://${MDM_HOSTNAME}:8443`.
MDM_BASE_URL=
# CADDY_TLS_ISSUER: `acme` for real Let's Encrypt certs (production, uses
# DNS-01 against Cloudflare), or `internal` for Caddy's self-signed CA
# (setup/dev; iOS won't trust it).
CADDY_TLS_ISSUER=acme
# Cloudflare API token for the gdlf zone (Zone:DNS:Edit). Required when
# CADDY_TLS_ISSUER=acme — Caddy uses DNS-01 challenge.
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=
