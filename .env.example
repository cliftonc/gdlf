# Public hostname or IP that kids' WireGuard clients dial in to.
# Must be reachable from the public internet (DDNS or static IP + port-forward).
WG_HOST=vpn.example.com
WG_PORT=51820

# Subnet handed out to WG peers. Each device gets one /32 inside this range.
WG_SUBNET=10.13.13.0/24

# Admin UI passwords
ADGUARD_ADMIN_PASSWORD=change-me
RULES_SVC_ADMIN_PASSWORD=change-me

# Dashboard bind
DASHBOARD_PORT=8080

# Optional: webhook for flagged events (leave blank to disable)
ALERT_WEBHOOK_URL=

# Optional: SMTP for email digests (leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

# Timezone used by the scheduler
TZ=Europe/London

# Activity-log retention (hourly prune; daily VACUUM).
# Trim events older than N days, AND cap at N rows — whichever bites first.
RETENTION_DAYS=7
MAX_EVENTS=200000
